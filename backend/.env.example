# TeamBrain backend — copy to .env (gitignored)

DATABASE_URL=
JWT_SECRET_KEY=
ENVIRONMENT=development

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8010/api/auth/google/callback

# LLM providers (fallback: Gemini -> Groq -> Mistral)
# Paste your keys here — never commit this file (gitignored)
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# S3-compatible storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# CORS (comma-separated) — must match frontend dev port
CORS_ORIGINS=http://localhost:3010
CSP_EXTRA_CONNECT_SRC=

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3010
