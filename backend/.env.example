# Copy to .env (gitignored) and fill in values

# --- Core ---
DATABASE_URL=
JWT_SECRET_KEY=
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010
FRONTEND_URL=http://localhost:3010

# --- Pilot signup ---
PILOT_INVITE_CODE=2026timtimol
PILOT_EMAIL_DOMAINS=

# --- Admin notifications ---
ADMIN_NOTIFICATION_EMAIL=diamouhamadou644@gmail.com
# SMTP_* — required in production to email team invites to invitees (not just admin notify)
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=TeamBrain <noreply@teambrain.app>
# SMTP_USE_TLS=true

# --- LLM (at least one for Ask AI) ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- File storage (Supabase Dashboard → Storage → S3) ---
S3_BUCKET=teambrain-uploads
S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true

# --- WhatsApp (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Production only (Railway) ---
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app

