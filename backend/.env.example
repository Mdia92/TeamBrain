# TeamBrain backend — copy to .env (gitignored)

DATABASE_URL=
JWT_SECRET_KEY=
ENVIRONMENT=development

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8010/api/auth/google/callback

# LLM providers (fallback: Gemini -> Groq -> Mistral)
# Paste your keys here — never commit this file (gitignored)
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# S3-compatible storage (Supabase: Dashboard → Storage → S3)
S3_BUCKET=teambrain-uploads
S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# CORS (comma-separated) — must match frontend dev port
CORS_ORIGINS=http://localhost:3010
CSP_EXTRA_CONNECT_SRC=

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3010

# PayDunya (paiement FCFA — laisser vide jusqu'au compte marchand)
PAYDUNYA_API_KEY=
PAYDUNYA_MASTER_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=sandbox

# Demo seed (local only — required for scripts/seed_timtimol.py)
SEED_DEMO_EMAIL=amadou@timtimol.sn
SEED_DEMO_PASSWORD=

# Assistant personality (Xam = « savoir » en wolof)
ASSISTANT_NAME=Xam
# ASSISTANT_PERSONALITY=  # optional override; leave empty for default tone block

# Per-org rules defaults — override in Paramètres → Règles (stored in organizations.settings.policy)
# See backend/app/policy/default_policy.yaml

# Firebase Cloud Messaging (JSON service account — single line, no newlines)
FIREBASE_SERVICE_ACCOUNT_JSON=
