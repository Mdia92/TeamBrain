# TeamBrain backend — copy to .env (gitignored)

DATABASE_URL=
JWT_SECRET_KEY=
ENVIRONMENT=development

# LLM providers (fallback: Gemini -> Groq -> Mistral)
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Supabase Storage S3 — Dashboard → Storage → S3 (NOT anon/service_role JWT keys)
S3_BUCKET=teambrain-uploads
S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Production (Railway) ---
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# PILOT_INVITE_CODE=2026timtimol
# PILOT_EMAIL_DOMAINS=   # optional: timtimol.org,timtimol.sn
# PILOT_MODE=true

# Local dev CORS
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010
FRONTEND_URL=http://localhost:3010

# PayDunya (optional)
PAYDUNYA_API_KEY=
PAYDUNYA_MASTER_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=sandbox

# Optional Google OAuth (existing accounts only — not required for pilot)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://your-api.railway.app/api/auth/google/callback

# Local seed script only (python scripts/seed_timtimol.py) — never commit
# SEED_DEMO_PASSWORD=

# Assistant (LLM system prompt)
ASSISTANT_NAME=Ask AI

# Firebase push (optional)
FIREBASE_SERVICE_ACCOUNT_JSON=
